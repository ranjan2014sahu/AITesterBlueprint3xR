{
  "name": "blast-jira-testplan",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "BLAST: lightweight React + Express app that turns a Jira ID into a formal QA Test Plan via GROQ.",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"node server.js\" \"vite\"",
    "server": "node server.js",
    "client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "handshake": "node tools/handshake.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^5.4.2"
  }
}
